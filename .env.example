# Discord application
DISCORD_BOT_TOKEN=""          # Bot token from the Discord Developer Portal
DISCORD_CLIENT_ID=""          # Application (client) ID
GUILD_ID=""                   # Your server ID (registers commands instantly to one guild; omit for global)

# Bastion backend
BASTION_API_URL="https://bastiondev.org"
BOT_HMAC_KEY=""               # Must match BOT_HMAC_KEY in the Bastion app env

# Access control
OWNER_IDS=""                  # Comma-separated Discord IDs allowed to run admin commands (empty = everyone)

# Buyer panel config (used by /setpanel and the buyer buttons)
PANEL_PROJECT_ID=""           # Project ID the panel serves (keys are looked up/created here)
SCRIPT_PUBLIC_ID=""           # Script publicId used for the "Get Script" loader snippet
BUYER_ROLE_ID=""              # Role granted to verified buyers (Redeem Key / Get Role)
HWID_COOLDOWN_HOURS="24"      # Cooldown between buyer self-service HWID resets
